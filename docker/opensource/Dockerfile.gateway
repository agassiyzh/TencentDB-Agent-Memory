# TencentDB Agent Memory Gateway — Standalone Open Source Image
#
# Runs the Gateway directly from the repository source tree.
# Suitable for standalone deployments that only need the memory gateway,
# without bundling Hermes itself.

FROM node:22-bookworm-slim

ENV NODE_ENV=production
ENV TDAI_GATEWAY_PORT=8420
ENV TDAI_GATEWAY_HOST=0.0.0.0
ENV TDAI_DATA_DIR=/opt/data/tdai-memory

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 make g++ ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev && npm cache clean --force

COPY . .

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -sf http://localhost:${TDAI_GATEWAY_PORT}/health || exit 1

EXPOSE 8420
VOLUME ["/opt/data"]

CMD ["node", "--import", "tsx/esm", "src/gateway/server.ts"]
